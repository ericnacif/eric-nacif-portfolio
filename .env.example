# ID de medição do Google Analytics 4.
# Copie este arquivo para .env e preencha com seu ID real.
# Deixe vazio (ou remova) para desativar o analytics.
VITE_GA_ID=

# ---------------------------------------------------------------------------
# Envio de e-mail do formulário de contato (Netlify Function + Resend).
# Configure estas variáveis no painel do Netlify (Site settings > Environment
# variables). NÃO commite valores reais — este arquivo é só um exemplo.
# ---------------------------------------------------------------------------

# Chave de API do Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Remetente. Precisa de um domínio verificado no Resend.
# Ex.: "Eric Nacif <contato@ericnacif.dev>"
# Antes de verificar o domínio, use "onboarding@resend.dev" (só envia para o e-mail da sua conta).
MAIL_FROM=Eric Nacif <contato@ericnacif.dev>

# Destino dos contatos recebidos pelo site.
MAIL_TO=naciferic7@gmail.com
